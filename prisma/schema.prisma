generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String   @id @default(cuid())
  clerkUserId          String   @unique
  email                String   @unique
  name                 String?
  role                 Role     @default(VIEWER)
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  billingPlan          BillingPlan @default(FREE)
  notifyEmail          Boolean  @default(true)
  notifySms            Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Lead {
  id             String          @id @default(cuid())
  fullName       String
  company        String?
  email          String?
  phone          String?
  serviceType    String
  source         LeadSource      @default(WEBSITE)
  status         LeadStatus      @default(NEW)
  urgency        LeadUrgency     @default(MEDIUM)
  location       String?
  estimatedCents Int?
  notes          String?
  nextFollowUpAt DateTime?
  lastContactedAt DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  jobs           Job[]
  activityEvents ActivityEvent[]

  @@index([status])
  @@index([nextFollowUpAt])
  @@index([createdAt])
}

model Job {
  id              String          @id @default(cuid())
  leadId          String?
  title           String
  serviceType     String
  status          JobStatus       @default(SCHEDULED)
  scheduledFor    DateTime?
  address         String?
  quotedCents     Int?
  finalCents      Int?
  quoteStatus     QuoteStatus     @default(DRAFT)
  quotedAt        DateTime?
  quoteApprovedAt DateTime?
  invoiceStatus   InvoiceStatus   @default(NOT_SENT)
  invoiceSentAt   DateTime?
  invoicePaidAt   DateTime?
  notes           String?
  completedAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  lead            Lead?           @relation(fields: [leadId], references: [id], onDelete: SetNull)
  activityEvents  ActivityEvent[]

  @@index([status])
  @@index([scheduledFor])
  @@index([quoteStatus])
  @@index([invoiceStatus])
}

model ActivityEvent {
  id         String    @id @default(cuid())
  leadId     String?
  jobId      String?
  kind       String
  message    String
  metadata   Json?
  createdAt  DateTime  @default(now())
  lead       Lead?     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  job        Job?      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
  @@index([jobId, createdAt])
  @@index([createdAt])
}

enum Role {
  OWNER
  ADMIN
  SALES
  OPS
  VIEWER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUOTED
  BOOKED
  COMPLETED
  LOST
}

enum LeadSource {
  WEBSITE
  INSTAGRAM
  FACEBOOK
  GOOGLE
  REFERRAL
  PHONE
  OTHER
}

enum LeadUrgency {
  LOW
  MEDIUM
  HIGH
}

enum JobStatus {
  DRAFT
  QUOTED
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum QuoteStatus {
  DRAFT
  SENT
  APPROVED
  DECLINED
}

enum InvoiceStatus {
  NOT_SENT
  SENT
  PAID
  OVERDUE
}

enum BillingPlan {
  FREE
  STARTER
  PRO
  TEAM
}
